  "user_level_adapter": {
    "levels": {
      "beginner": {
        "response_mode": "guided",
        "behavior": [
          "Ask short guided questions for missing safety-critical fields.",
          "Explain selected tool/material/operation in simple terms.",
          "Do not overwhelm with raw G-code before confirming intent."
        ]
      },
      "intermediate": {
        "response_mode": "assisted",
        "behavior": [
          "Show selected F/S/Z and concise rationale.",
          "Allow user to edit parameters within Neo4j operating range.",
          "Show validation report after generation."
        ]
      },
      "expert": {
        "response_mode": "direct",
        "behavior": [
          "Return G-code, Neo4j context, and validation report directly.",
          "Keep explanation minimal.",
          "Do not ask unnecessary clarification if all required fields are present."
        ]
      },
      "unknown": {
        "response_mode": "safe_default",
        "behavior": [
          "Use beginner/intermediate hybrid style.",
          "Ask for missing material/tool/depth/origin when needed.",
          "Never infer unsafe parameters."
        ]
      }
    },
    "required_intent_fields": [
      "material",
      "operation",
      "geometry",
      "depth",
      "origin_or_coordinate_frame",
      "tool_preference_or_auto_select"
    ],
    "dangerous_missing_fields": [
      "material",
      "depth",
      "origin_or_coordinate_frame"
    ]
  },
  "tool_contracts": {
    "get_neo4j_context": {
      "must_call_before_final_gcode": true,
      "input": [
        "user_request",
        "user_level",
        "material?",
        "operation?",
        "tool?",
        "geometry?",
        "depth?"
      ],
      "output_required": [
        "machine",
        "axis_limits",
        "selected_tool",
        "selected_operation",
        "selected_material",
        "operating_range",
        "source"
      ],
      "source_of_truth": "Neo4j Knowledge Graph"
    },
    "validate_gcode": {
      "must_call_before_final_response": true,
      "checks": [
        "F within operating_range.feed_min/feed_max",
        "S within operating_range.spindle_min/spindle_max",
        "Z stepdown/depth within operating_range.depth_min/depth_max",
        "X/Y/Z within Axis travel",
        "safe header includes G21/G90/G17 or project-standard equivalent",
        "no machine run unless later CHECK/gate approves"
      ]
    },
    "generate_gcode": {
      "allowed_after": [
        "get_neo4j_context"
      ],
      "must_use": [
        "operating_range",
        "axis_limits",
        "user_level_adapter"
      ]
    }
  },
  "evaluation_matrix": {
    "C1_tool_ordering": {
      "measure": "Tool call log per session: get_neo4j_context appears before final G-code generation.",
      "threshold": "100% sessions",
      "status": "required"
    },
    "C2_first_pass_range_compliance": {
      "measure": "Parse F/S in first generated G-code and compare with Neo4j operating_range.",
      "threshold": ">=90% first generations pass without correction",
      "status": "required"
    },
    "C3_self_correction": {
      "measure": "If first generation violates range, agent calls validate_gcode and fixes within <=2 additional rounds, max_tool_rounds=5.",
      "threshold": ">=95% of first-pass failures corrected",
      "status": "required"
    },
    "C4_user_level_adaptation": {
      "measure": "Agent response style matches beginner/intermediate/expert/unknown user level without changing safety constraints.",
      "threshold": ">=90% style match; 100% safety-critical missing-info cases ask/stop",
      "status": "added_in_06A"
    }
  },
  "source_of_truth_contract": {
    "feed_spindle_depth": "Neo4j OperatingRange returned by get_neo4j_context",
    "axis_limits": "Neo4j Axis/Machine data",
    "tool_max_rpm": "Neo4j Tool.max_rpm",
    "user_interaction_style": "User-Level Adapter section in this knowledge base",
    "gcode_validity": "validate_gcode result using Neo4j context",
    "machine_run_permission": "Existing machine gate/CHECK/Confirm flow, not Agent Client alone",
    "mcp_transport": "Future MCP layer only changes how tools are called, not the meaning or logic of tools"
  },
  "guardrails": [
    "Do not output final G-code before get_neo4j_context.",
    "Do not use LLM internal knowledge as source for F/S/depth when Neo4j operating_range exists.",
    "Do not exceed feed/spindle/depth/axis limits.",
    "Do not skip validate_gcode before final answer.",
    "Do not run the real machine directly from Agent Client; machine run remains behind CHECK/Confirm gate.",
    "Do not use one generic prompt style for all skill levels.",
    "Do not update Neo4j schema without updating this knowledge base and evaluation matrix.",
    "Do not implement MCP before Neo4j context and validation contracts are stable."
  ],
  "update_protocol": [
    "Edit this JSON and the Markdown knowledge base together.",
    "If changing Neo4j data, update operating_ranges and source_of_truth_contract.",
    "If adding a new operation/material/tool, add at least one evaluation scenario.",
    "If changing prompt behavior, update C4 tests.",
    "After any update, rerun C1/C2/C3/C4 eval harness when available."
  ],
