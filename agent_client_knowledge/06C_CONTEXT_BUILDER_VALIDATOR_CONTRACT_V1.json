  "guardrails": [
    "Context Builder must not fabricate an OperatingRange.",
    "Validator must fail if context is missing.",
    "Validator must treat out-of-range F/S/depth as BLOCKER.",
    "Context Builder must return needs_clarification or unsupported instead of guessing unsupported operations like drilling if no graph data exists.",
    "G-code validity is not the same as machine-run permission."
  ]
